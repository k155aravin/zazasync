{
  "name": "zazasync-cloudflare-worker",
  "version": "0.1.0",
  "private": true,
  "description": "Cloudflare Worker data pipeline and cached API for ZazaSync SQDC inventory intelligence.",
  "type": "module",
  "scripts": {
    "dev": "wrangler dev",
    "deploy": "wrangler deploy",
    "deploy:staging": "wrangler deploy --env staging",
    "db:migrate:local": "wrangler d1 migrations apply ZAZASYNC_DB --local",
    "db:migrate:remote": "wrangler d1 migrations apply ZAZASYNC_DB --remote",
    "typecheck": "tsc --noEmit",
    "test:crawl:local": "wrangler dev --test-scheduled"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20260520.0",
    "typescript": "^5.8.3",
    "wrangler": "^4.18.0"
  }
}
